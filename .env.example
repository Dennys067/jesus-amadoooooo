# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase PostgreSQL Database Configuration
# Obtain these values from your Supabase Project Settings > Database
SQL_HOST="aws-0-us-east-1.pooler.supabase.com" # Use Supabase connection pooler or direct host
SQL_PORT="5432"                                 # Port (usually 5432 or 6543)
SQL_USER="postgres.your-supabase-project-id"   # Supabase DB User
SQL_PASSWORD="your-supabase-db-password"       # Supabase DB Password
SQL_DB_NAME="postgres"                         # Database Name (default is postgres)
SQL_ADMIN_USER="postgres.your-supabase-project-id" # Admin User for migrations (usually same as user)
SQL_ADMIN_PASSWORD="your-supabase-db-password" # Admin Password for migrations (usually same as password)
SQL_SSL="true"                                 # Set to true to force SSL (required for Supabase)

# Supabase Client Configuration (Required for Storage/Uploads and Auth)
# Obtain these values from your Supabase Project Settings > API
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

